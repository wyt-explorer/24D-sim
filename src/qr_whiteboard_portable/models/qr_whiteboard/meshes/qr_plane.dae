<?xml version="1.0" encoding="utf-8"?>
<COLLADA xmlns="http://www.collada.org/2005/11/COLLADASchema" version="1.4.1">
  <asset>
    <unit meter="1" name="meter"/>
    <up_axis>Z_UP</up_axis>
  </asset>

  <library_images>
    <image id="qr_board_image" name="qr_board_image">
      <init_from>../materials/textures/qr_board.png</init_from>
    </image>
  </library_images>

  <library_effects>
    <effect id="qr_board_effect">
      <profile_COMMON>
        <newparam sid="qr_board_surface">
          <surface type="2D">
            <init_from>qr_board_image</init_from>
          </surface>
        </newparam>
        <newparam sid="qr_board_sampler">
          <sampler2D>
            <source>qr_board_surface</source>
          </sampler2D>
        </newparam>
        <technique sid="common">
          <lambert>
            <diffuse>
              <texture texture="qr_board_sampler" texcoord="UVSET0"/>
            </diffuse>
          </lambert>
        </technique>
      </profile_COMMON>
    </effect>
  </library_effects>

  <library_materials>
    <material id="qr_board_material" name="qr_board_material">
      <instance_effect url="#qr_board_effect"/>
    </material>
  </library_materials>

  <library_geometries>
    <geometry id="qr_plane_geometry" name="qr_plane">
      <mesh>
        <source id="positions">
          <float_array id="positions_array" count="12">
            0 1.125 1
            0 -1.125 1
            0 -1.125 -1
            0 1.125 -1
          </float_array>
          <technique_common>
            <accessor source="#positions_array" count="4" stride="3">
              <param name="X" type="float"/>
              <param name="Y" type="float"/>
              <param name="Z" type="float"/>
            </accessor>
          </technique_common>
        </source>

        <source id="normals">
          <float_array id="normals_array" count="3">-1 0 0</float_array>
          <technique_common>
            <accessor source="#normals_array" count="1" stride="3">
              <param name="X" type="float"/>
              <param name="Y" type="float"/>
              <param name="Z" type="float"/>
            </accessor>
          </technique_common>
        </source>

        <source id="texcoords">
          <float_array id="texcoords_array" count="8">
            0 0
            1 0
            1 1
            0 1
          </float_array>
          <technique_common>
            <accessor source="#texcoords_array" count="4" stride="2">
              <param name="S" type="float"/>
              <param name="T" type="float"/>
            </accessor>
          </technique_common>
        </source>

        <vertices id="vertices">
          <input semantic="POSITION" source="#positions"/>
        </vertices>

        <triangles material="qr_mat" count="2">
          <input semantic="VERTEX" source="#vertices" offset="0"/>
          <input semantic="NORMAL" source="#normals" offset="1"/>
          <input semantic="TEXCOORD" source="#texcoords" offset="2" set="0"/>
          <p>
            0 0 0  1 0 1  2 0 2
            0 0 0  2 0 2  3 0 3
          </p>
        </triangles>
      </mesh>
    </geometry>
  </library_geometries>

  <library_visual_scenes>
    <visual_scene id="Scene" name="Scene">
      <node id="qr_plane" name="qr_plane">
        <instance_geometry url="#qr_plane_geometry">
          <bind_material>
            <technique_common>
              <instance_material symbol="qr_mat" target="#qr_board_material">
                <bind_vertex_input semantic="UVSET0" input_semantic="TEXCOORD" input_set="0"/>
              </instance_material>
            </technique_common>
          </bind_material>
        </instance_geometry>
      </node>
    </visual_scene>
  </library_visual_scenes>

  <scene>
    <instance_visual_scene url="#Scene"/>
  </scene>
</COLLADA>
